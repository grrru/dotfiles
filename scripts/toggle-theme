#!/bin/bash

STATE_FILE="$HOME/.theme_mode"
# Resolve the dotfiles root from this script's location (scripts/ -> repo root),
# falling back to ~/dotfiles when invoked through a copied path.
DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"
[ -d "$DOTFILES/ghostty" ] || DOTFILES="$HOME/dotfiles"
LIGHT_THEME="Catppuccin Latte"
DARK_THEME="TokyoNight Night"

# Portable in-place sed: GNU sed (Linux) takes `-i`, BSD sed (macOS) needs `-i ''`.
sed_inplace() {
  if sed --version >/dev/null 2>&1; then
    sed -i "$@"
  else
    sed -i '' "$@"
  fi
}

# Determine new mode
if [ -f "$STATE_FILE" ] && [ "$(cat "$STATE_FILE")" = "dark" ]; then
  NEW_MODE="light"
else
  NEW_MODE="dark"
fi
echo "$NEW_MODE" >"$STATE_FILE"

# === Ghostty ===
GHOSTTY_CONFIG="$DOTFILES/ghostty/config"
if [ "$NEW_MODE" = "dark" ]; then
  sed_inplace "s/^theme = .*/theme = $DARK_THEME/" "$GHOSTTY_CONFIG"
  sed_inplace 's/^font-thicken = true/font-thicken = false/' "$GHOSTTY_CONFIG"
else
  sed_inplace "s/^theme = .*/theme = $LIGHT_THEME/" "$GHOSTTY_CONFIG"
  sed_inplace 's/^font-thicken = false/font-thicken = true/' "$GHOSTTY_CONFIG"
fi

# === Tmux ===
if [ "$NEW_MODE" = "dark" ]; then
  tmux set-option -g status-bg "#1e1e2e"
  tmux set-option -g status-fg "#cdd6f4"
  tmux set-option -g pane-border-style "fg=#585b70"
  tmux set-option -g pane-active-border-style "fg=#89b4fa"
else
  tmux set-option -g status-bg "#d5d6db"
  tmux set-option -g status-fg "#343b58"
  tmux set-option -g pane-border-style "fg=#585b70"
  tmux set-option -g pane-active-border-style "fg=#89b4fa"
fi

tmux display-message "Theme: $NEW_MODE"
